# Autonote Settings Example Template
# Copy this file to .autonoterc or ~/.autonoterc and fill in your values.

# Directory to save all original WAV/MP3 files, raw transcripts, and final markdown 
RECORDINGS_DIR="./recordings"

# Transcription provider: "local" (faster-whisper) or "assemblyai" (cloud API)
TRANSCRIPTION_PROVIDER="local"

# AssemblyAI API key — required when TRANSCRIPTION_PROVIDER="assemblyai"
# ASSEMBLYAI_API_KEY="your-api-key-here"
# AssemblyAI cost per minute in USD (default: $0.012 for universal-3-pro)
# ASSEMBLYAI_COST_PER_MINUTE="0.012"

# Whisper settings — only used when TRANSCRIPTION_PROVIDER="local"
# Valid models: tiny, base, small, medium, turbo, large-v3
WHISPER_MODEL="turbo"
WHISPER_LANGUAGE="en"

# Ollama settings for local LLM models (legacy, still works)
OLLAMA_MODEL="llama3.1:8b"
OLLAMA_REFORMAT_MODEL="llama3.1:8b"
OLLAMA_URL="http://localhost:11434"

# Unified LLM Model (used for summarization, reformatting, metadata extraction)
# Supports local Ollama models and cloud providers:
# - Local: llama3.1:8b, mistral, etc. (automatically prefixed with ollama/)
# - OpenAI: openai/gpt-4o, openai/gpt-4o-mini (requires OPENAI_API_KEY)
# - Anthropic: anthropic/claude-3-5-sonnet-20240620 (requires ANTHROPIC_API_KEY)
# - Gemini: gemini/gemini-1.5-flash (requires GEMINI_API_KEY)
LLM_MODEL="ollama/llama3.1:8b"

# Optional: Path to Obsidian vault to copy final outputs
VAULT_DIR="/path/to/my/obisdian/vault"

# Optional: Exact path to an Index file to dynamically append Meeting links to
MEETING_INDEX="/path/to/my/obisdian/vault/Meetings.md"

# Path to meetings calendar file for recurring meeting patterns (used for LLM title inference)
# Generate with: autonote calendar-sync
MEETINGS_CALENDAR="./meetings_calendar.yml"

# Path to the entity dictionary to dynamically inject [[wikilinks]]
ENTITIES_FILE="./entities.yml"

# Microphone input volume amplification scaling factor
MIC_VOLUME="2.0"

# Print internal execution traces to console
DEBUG="false"
